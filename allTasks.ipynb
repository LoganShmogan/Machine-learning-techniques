    "import yfinance as yf\n",
    "import pandas as pd\n",
    "\n",
    "# Get stock data\n",
    "ticker = yf.Ticker(\"AAPL\")\n",
    "df = ticker.history(period=\"5y\")\n",
    "\n",
    "# Define Features (X) and Target (y)\n",
    "X = df[[\"Open\", \"High\", \"Low\", \"Volume\"]]\n",
    "y = df[\"Close\"]\n",
    "\n",
    "# Write features to console\n",
    "print(\"Features (X) sample:\")\n",
    "print(X.head())\n",
    "print(\"\\nTarget (y) sample:\")\n",
    "print(y.head())\n"
   ]
  },
